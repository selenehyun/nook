          "stringUnit": {
            "state": "translated",
            "value": "「%@」は有効な URL ではありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유효한 URL이 아닙니다: '%@'"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”不是有效的网址。"
          }
        }
      }
    },
