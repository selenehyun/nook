        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フィードの取得に失敗しました（HTTP %lld）。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "订阅源请求失败，HTTP %lld。"
          }
        }
      }
    },
    "No RSS or Atom feed link was found at %@." : {
      "localizations" : {
