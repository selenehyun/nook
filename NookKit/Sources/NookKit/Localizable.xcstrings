        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "编写规则"
          }
        }
      }
    },
    "A filter hides any story that matches it. Use plain **Text** for a word or phrase, or a **Regex** for a pattern." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A filter hides any story that matches it. Use plain **Text** for a word or phrase, or a **Regex** for a pattern."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フィルタは一致する記事を隠します。単語やフレーズには **テキスト**、パターンには **正規表現** を使います。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필터는 일치하는 글을 숨깁니다. 단어나 구절에는 **텍스트**, 패턴에는 **정규식**을 사용하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "过滤器会隐藏所有匹配的文章。单词或短语用 **文本**，模式用 **正则表达式**。"
          }
        }
      }
    },
    "Choose what it checks" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose what it checks"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "検査対象を選ぶ"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "검사 대상 선택"
          }
