          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "원하지 않는 글 걸러내기"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "过滤掉你不想看的文章"
          }
        }
