    "Choose an iCloud Drive folder before adding feeds." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose an iCloud Drive folder before adding feeds."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "피드를 추가하려면 먼저 iCloud Drive 폴더를 선택하세요."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フィードを追加する前に iCloud Drive のフォルダを選択してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "添加订阅源前，请先选择一个 iCloud 云盘文件夹。"
          }
        }
      }
    },
    "The saved sync folder permission expired. Choose the folder again." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The saved sync folder permission expired. Choose the folder again."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저장된 동기화 폴더 권한이 만료되었습니다. 폴더를 다시 선택하세요."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存された同期フォルダのアクセス権が失効しました。もう一度フォルダを選択してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已保存的同步文件夹权限已过期。请重新选择文件夹。"
          }
        }
      }
    },
    "'%@' is not a valid URL." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%@' is not a valid URL."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "유효한 URL이 아닙니다: '%@'"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」は有効な URL ではありません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@”不是有效的网址。"
          }
        }
      }
    },
    "No RSS or Atom entries were found at %@." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No RSS or Atom entries were found at %@."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@에서 RSS나 Atom 항목을 찾지 못했습니다."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ に RSS／Atom のエントリが見つかりませんでした。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 %@ 未找到 RSS 或 Atom 条目。"
          }
        }
      }
    },
    "The feed request failed with HTTP %lld." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The feed request failed with HTTP %lld."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "피드를 불러오지 못했습니다 (HTTP %lld)."
