        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "나중에"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以后再说"
          }
        }
      }
    },
