          }
        }
      }
    },
    "Your key is stored only on this device and is never synced. When Gemini is selected, article text is sent to Google to translate it." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キーはこの端末にのみ保存され、同期されません。Gemini を選択すると、翻訳のために記事のテキストが Google に送信されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "키는 이 기기에만 저장되며 동기화되지 않습니다. Gemini를 선택하면 번역을 위해 기사 텍스트가 Google로 전송됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "密钥仅存储在此设备上，绝不同步。选择 Gemini 时，文章文本会发送给 Google 进行翻译。"
          }
        }
      }
    },
    "Add Filter" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add Filter"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フィルタを追加"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필터 추가"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "添加过滤器"
          }
        }
      }
    },
    "Articles matching an enabled filter are hidden from every list and unread count, and collected under Filtered. Filters sync across your devices." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Articles matching an enabled filter are hidden from every list and unread count, and collected under Filtered. Filters sync across your devices."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効なフィルタに一致する記事は、すべてのリストと未読数から隠され、「フィルタ済み」にまとめられます。フィルタはデバイス間で同期されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화된 필터와 일치하는 글은 모든 목록과 안 읽음 개수에서 숨겨지고 ‘필터됨’에 모입니다. 필터는 기기 간에 동기화됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "与已启用过滤器匹配的文章会从所有列表和未读计数中隐藏，并归入“已过滤”。过滤器会在您的设备间同步。"
          }
        }
      }
    },
