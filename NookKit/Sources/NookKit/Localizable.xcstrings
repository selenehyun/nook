        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@에서 RSS나 Atom 피드 링크를 찾지 못했습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %@ 未找到 RSS 或 Atom 订阅源链接。"
          }
        }
      }
    },
