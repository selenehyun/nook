    "%lld selected": {
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld selected"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld selected"
                }
              }
            }
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 件を選択中"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld개 선택됨"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已选择 %lld 项"
          }
