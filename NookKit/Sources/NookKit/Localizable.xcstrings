    "Filtered" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filtered"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フィルタ済み"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필터됨"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已过滤"
          }
        }
      }
    },
    "Filtered stories leave every list and unread count — they're never treated as unread. Find them anytime under **Filtered** at the bottom of the sidebar. Nothing is deleted: turn a filter off and its stories come right back." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filtered stories leave every list and unread count — they're never treated as unread. Find them anytime under **Filtered** at the bottom of the sidebar. Nothing is deleted: turn a filter off and its stories come right back."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フィルタされた記事はすべてのリストと未読数から外れ、未読として扱われません。サイドバー下部の **フィルタ済み** でいつでも確認できます。削除ではないので、フィルタをオフにすれば戻ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "걸러진 글은 모든 목록과 안 읽음 개수에서 빠지며, 안 읽음으로 취급되지 않습니다. 사이드바 맨 아래 **필터됨**에서 언제든 볼 수 있어요. 삭제되는 게 아니라서, 필터를 끄면 다시 나타납니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "被过滤的文章会从所有列表和未读计数中移除，且不会被视为未读。你可以随时在侧边栏底部的**已过滤**中找到它们。它们不会被删除——关闭过滤器就会重新出现。"
          }
        }
      }
    },
    "Filters quietly hide stories that match rules you set — so your lists stay about what you actually want to read." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filters quietly hide stories that match rules you set — so your lists stay about what you actually want to read."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定したルールに一致する記事をフィルタがそっと隠すので、リストは本当に読みたいものだけに保たれます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필터는 설정한 규칙에 맞는 글을 조용히 숨겨, 목록이 정말 읽고 싶은 것들로 유지되게 합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "过滤器会悄悄隐藏符合你所设规则的文章，让列表只留下你真正想读的内容。"
          }
        }
      }
    },
    "Filters sync through your folder, so the same stories stay hidden on every device." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filters sync through your folder, so the same stories stay hidden on every device."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フィルタはフォルダを通じて同期され、どのデバイスでも同じ記事が隠れます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필터는 동기화 폴더를 통해 공유되어, 모든 기기에서 같은 글이 숨겨집니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "过滤器通过你的文件夹同步，因此同一批文章会在每台设备上都被隐藏。"
          }
        }
      }
    },
