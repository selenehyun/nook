    "No RSS or Atom entries were found at %@.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No RSS or Atom entries were found at %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ に RSS／Atom のエントリが見つかりませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@에서 RSS나 Atom 항목을 찾지 못했습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %@ 未找到 RSS 或 Atom 条目。"
          }
        }
      }
    },
    "No RSS or Atom feed link was found at %@.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No RSS or Atom feed link was found at %@."
