    "Matching stories are hidden from every list and unread count, and collected under Filtered. Filters sync across your devices." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Matching stories are hidden from every list and unread count, and collected under Filtered. Filters sync across your devices."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一致する記事はすべてのリストと未読数から隠れ、「フィルタ済み」にまとまります。フィルタはデバイス間で同期されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일치하는 글은 모든 목록과 안 읽음 개수에서 숨겨지고 ‘필터됨’에 모입니다. 필터는 기기 간에 동기화됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "匹配的文章会从所有列表和未读计数中隐藏，并归入“已过滤”。过滤器会在你的设备间同步。"
          }
        }
      }
    },
