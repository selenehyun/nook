    "Filter out stories you don't want" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filter out stories you don't want"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
