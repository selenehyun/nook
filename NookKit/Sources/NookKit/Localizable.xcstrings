    "Choose an iCloud Drive folder before adding feeds.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose an iCloud Drive folder before adding feeds."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィードを追加する前に iCloud Drive のフォルダを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "피드를 추가하려면 먼저 iCloud Drive 폴더를 선택하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加订阅源前，请先选择一个 iCloud 云盘文件夹。"
          }
        }
      }
    },
    "Couldn't add %lld feeds": {
      "localizations": {
