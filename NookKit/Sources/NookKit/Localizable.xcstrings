    "Gemini classifies over the network and may cost money; article text is sent to Google. Apple Intelligence stays on device and free." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gemini classifies over the network and may cost money; article text is sent to Google. Apple Intelligence stays on device and free."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geminiはネットワークで分類し、費用が発生する場合があり、記事の内容がGoogleに送信されます。Apple Intelligenceは端末内で無料で動作します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gemini는 네트워크로 분류하며 비용이 발생할 수 있고, 글 내용이 Google로 전송됩니다. Apple Intelligence는 기기 내에서 무료로 동작합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gemini 通过网络分类，可能产生费用，文章内容会发送给 Google。Apple Intelligence 在设备本地运行且免费。"
          }
        }
      }
    },
