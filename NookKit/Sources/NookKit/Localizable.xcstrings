    "Use Download Articles to choose which stories to save. Saved articles open instantly without a connection and are kept on this device only." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Download Articles to choose which stories to save. Saved articles open instantly without a connection and are kept on this device only."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「記事をダウンロード」で保存する記事を選べます。保存した記事は接続なしで即座に開き、この端末にのみ保存されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "‘글 다운로드’로 저장할 글을 선택하세요. 저장된 글은 연결 없이도 즉시 열리며 이 기기에만 보관됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用“下载文章”选择要保存的文章。已保存的文章无需联网即可立即打开，且仅保存在此设备上。"
          }
        }
      }
    },
