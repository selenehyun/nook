    "Use the folder button in the main window to choose or change the iCloud Drive folder. Nook stores RSS data in NookLibrary.json inside that folder." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Use the folder button in the main window to choose or change the iCloud Drive folder. Nook stores RSS data in NookLibrary.json inside that folder." } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "메인 창의 폴더 버튼을 사용해 iCloud Drive 폴더를 선택하거나 변경하세요. Nook은 그 폴더 안의 NookLibrary.json에 RSS 데이터를 저장합니다." } }
      }
    },
    "Nook stores its RSS library in a folder you choose, so iCloud Drive can sync it like a vault." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Nook stores its RSS library in a folder you choose, so iCloud Drive can sync it like a vault." } },
