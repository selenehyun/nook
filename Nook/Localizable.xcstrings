    "Choose a folder in iCloud Drive and Nook keeps your feeds in sync across your devices.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a folder in iCloud Drive and Nook keeps your feeds in sync across your devices."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Drive 内のフォルダを選ぶと、Nook がデバイス間でフィードを同期します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Drive에서 폴더를 선택하면 여러 기기에서 피드가 동기화됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 iCloud 云盘中选择一个文件夹，Nook 会在你的设备之间同步订阅源。"
          }
        }
      }
    },
    "Choose a story from the article list.": {
      "localizations": {
