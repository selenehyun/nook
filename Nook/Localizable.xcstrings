    "Nook checks quietly in the background and shows a notice in the sidebar when an update is ready.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook はバックグラウンドで静かに確認し、アップデートの準備ができるとサイドバーでお知らせします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook은 백그라운드에서 조용히 확인하고, 업데이트가 준비되면 사이드바에 알려 줍니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook 会在后台静默检查，有更新就绪时会在边栏提示你。"
          }
        }
      }
    },
    "Nook keeps your feeds in a folder in iCloud Drive so they stay in sync across your devices.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook keeps your feeds in a folder in iCloud Drive so they stay in sync across your devices."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook は iCloud Drive 内のフォルダにフィードを保存し、デバイス間で同期します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook은 피드를 iCloud Drive의 한 폴더에 보관해 여러 기기에서 동기화되도록 합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook 将订阅源保存在 iCloud 云盘的文件夹中，让它们在你的设备之间保持同步。"
          }
        }
      }
    },
    "Nook stores its RSS library in a folder you choose, so iCloud Drive can sync it like a vault.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook stores its RSS library in a folder you choose, so iCloud Drive can sync it like a vault."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook は選んだフォルダに RSS ライブラリを保存するので、iCloud Drive が Vault のように同期できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook은 여러분이 선택한 폴더에 RSS 라이브러리를 저장합니다. 그러면 iCloud Drive가 이 폴더를 보관함처럼 동기화합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Nook 将 RSS 资料库保存在你选择的文件夹中，iCloud 云盘便能像保管库一样同步它。"
          }
        }
      }
    },
    "Nook will only close after it finds a valid feed.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効なフィードが見つかったときのみ閉じます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유효한 피드를 찾은 후에만 닫힙니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在找到有效订阅源后才会关闭。"
          }
        }
      }
