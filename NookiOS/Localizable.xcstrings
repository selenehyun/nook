    "Choose a sync folder so Nook keeps your feeds in sync across your devices." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose a sync folder so Nook keeps your feeds in sync across your devices."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同期フォルダを選ぶと、Nook がデバイス間でフィードを同期します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "동기화 폴더를 선택하면 Nook이 여러 기기에서 피드를 동기화합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择一个同步文件夹，Nook 会在你的设备之间同步订阅源。"
          }
        }
      }
    },
    "Choose how each feed's articles open in the web view. “Default” follows the In-App Browser setting above." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose how each feed's articles open in the web view. “Default” follows the In-App Browser setting above."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各フィードの記事を Web ビューでどう開くかを選びます。「デフォルト」は上の App 内ブラウザの設定に従います。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "각 피드의 글을 웹뷰에서 여는 방식을 선택하세요. “기본값”은 위의 인앱 브라우저 설정을 따릅니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择每个订阅源的文章在网页视图中的打开方式。“默认”将沿用上方的应用内浏览器设置。"
          }
        }
      }
    },
