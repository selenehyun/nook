    "At the end of a story, keep pulling up past the bottom to jump to the next one." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記事の末尾で下方向にさらに引っ張ると、次の記事に移動します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "글 끝에서 바닥 아래로 계속 당기면 다음 글로 넘어갑니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "读到文末时，继续向上拉过底部即可跳到下一篇。"
          }
        }
      }
    },
