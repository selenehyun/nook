    "Background App Refresh" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App のバックグラウンド更新"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "백그라운드 앱 새로고침"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
