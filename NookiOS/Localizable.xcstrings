    "Background App Refresh" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App のバックグラウンド更新"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "백그라운드 앱 새로고침"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "后台 App 刷新"
          }
        }
      }
    },
    "Background App Refresh is off, so Nook can't check for new articles in the background and no notifications will arrive. Tap above, then turn on Settings › General › Background App Refresh and enable it for Nook." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Background App Refresh is off, so Nook can't check for new articles in the background and no notifications will arrive. Tap above, then turn on Settings › General › Background App Refresh and enable it for Nook."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appのバックグラウンド更新がオフのため、Nookはバックグラウンドで新着記事を確認できず、通知も届きません。上をタップし、設定 › 一般 › Appのバックグラウンド更新をオンにして、Nookでも有効にしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "백그라운드 앱 새로고침이 꺼져 있어 Nook이 백그라운드에서 새 글을 확인할 수 없고 알림도 오지 않습니다. 위 항목을 누른 뒤, 설정 › 일반 › 백그라운드 앱 새로고침을 켜고 Nook에 대해서도 켜 주세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "后台App刷新已关闭，Nook 无法在后台检查新文章，也不会收到通知。请点按上方，然后在设置 › 通用 › 后台App刷新中开启，并为 Nook 启用。"
          }
        }
      }
    },
