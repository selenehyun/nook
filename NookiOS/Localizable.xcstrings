    "Choose how each feed's articles open in the web view. “Default” follows the In-App Browser setting above." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose how each feed's articles open in the web view. “Default” follows the In-App Browser setting above."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各フィードの記事を Web ビューでどう開くかを選びます。「デフォルト」は上の App 内ブラウザの設定に従います。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "각 피드의 글을 웹뷰에서 여는 방식을 선택하세요. “기본값”은 위의 인앱 브라우저 설정을 따릅니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择每个订阅源的文章在网页视图中的打开方式。“默认”将沿用上方的应用内浏览器设置。"
          }
        }
      }
    },
