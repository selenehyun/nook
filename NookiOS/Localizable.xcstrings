    "Double-tap anywhere on an article to star it — and find it later under Starred." : {
      "extractionState" : "stale",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記事のどこかをダブルタップするとスターが付き、後で「スター付き」から見つけられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "글 아무 곳이나 더블 탭하면 별표가 됩니다. 나중에 별표 탭에서 찾을 수 있어요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在文章任意处双击即可收藏，稍后可在“已加星标”中找到。"
          }
        }
      }
    },
    "Double-tap anywhere on the article to star it — try it now, or tap Next." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
