<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Branded launch screen (logo centered at 96pt on LaunchBackground) so the
	     first frame isn't an empty black screen and matches the SwiftUI splash
	     exactly. A storyboard is used (not the UILaunchScreen dict) for
	     deterministic logo sizing. -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.tim.nook.ios.refresh</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.tim.nook.ios</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>nook</string>
			</array>
		</dict>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- RSS feeds are arbitrary, user-chosen URLs; many are served over
		     HTTP or redirect through HTTP hosts (e.g. FeedBurner), so cleartext
		     loads must be allowed for the reader to fetch them and their icons. -->
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
</dict>
</plist>
